{
  "name": "apexyard",
  "version": "3.0.0",
  "description": "Multi-project forge — single source of truth generates OpenCode + Codex CLI",
  "type": "module",
  "private": true,
  "bin": {
    "apexyard-sync": "./bin/sync.ts"
  },
  "scripts": {
    "sync": "bun run bin/sync.ts",
    "sync:watch": "bun run --watch bin/sync.ts",
    "sync:check": "bun run bin/sync.ts --check",
    "migrate": "bun run bin/migrate-from-claude.ts",
    "test": "bun test",
    "test:hooks": "bun run bin/test-hooks.ts",
    "test:plugin": "bun run bin/test-plugin-wiring.ts"
  },
  "dependencies": {
    "@opencode-ai/plugin": "^1.0.0",
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "js-yaml": "^4.1.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/js-yaml": "^4.0.9",
    "typescript": "^5.6.0"
  },
  "engines": {
    "bun": ">=1.3.0"
  }
}
