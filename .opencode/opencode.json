{
  "$schema": "https://opencode.ai/config.json",
  "model": "opencode/minimax-m3-free",
  "default_agent": "build",
  "instructions": [
    ".opencode/instructions/INDEX.md"
  ],
  "provider": {
    "opencode": {},
    "openai": {
      "options": {
        "apiKey": "{env:OPENAI_API_KEY}"
      }
    }
  },
  "agent": {
    "backend-engineer": {
      "model": "opencode/minimax-m3-free",
      "mode": "subagent",
      "permission": {
        "edit": "allow",
        "bash": "ask",
        "webfetch": "allow",
        "websearch": "allow"
      }
    },
    "code-reviewer": {
      "model": "openai/gpt-5",
      "mode": "subagent",
      "permission": {
        "edit": "deny",
        "bash": "ask",
        "webfetch": "deny",
        "websearch": "deny"
      }
    },
    "tech-lead": {
      "model": "openai/gpt-5",
      "mode": "subagent",
      "permission": {
        "edit": "allow",
        "bash": "ask",
        "webfetch": "allow",
        "websearch": "allow"
      }
    }
  },
  "permission": {
    "edit": "ask",
    "bash": "ask",
    "webfetch": "allow",
    "websearch": "allow"
  },
  "plugin": [
    ".opencode/plugin/apexyard-hooks.ts"
  ],
  "mcp": {},
  "small_model": "opencode/minimax-m3-free"
}
